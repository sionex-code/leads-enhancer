# ---- LeadsFunda SaaS environment ----
# Copy to .env.local (dev) or .env (prod) and fill in real values.

# Postgres (Phase 1)
DATABASE_URL=postgresql://leadsfunda:password@localhost:5432/leadsfunda
PG_POOL_MAX=10

# Auth.js / Google sign-in (Phase 2)
# Generate AUTH_SECRET with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Public base URL of the app host — this is where ALL auth happens, so the Google
# OAuth client must allow <this>/api/auth/callback/google.
# Prod: https://app.leadsfunda.com   Dev: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Two-host split (prod). The app runs on the app host; the marketing landing on
# the apex. Leave BLANK in local dev to keep everything on a single host.
# These are inlined at build time (NEXT_PUBLIC_*), so set them before `npm run build`.
NEXT_PUBLIC_APP_URL=https://app.leadsfunda.com
NEXT_PUBLIC_MARKETING_URL=https://leadsfunda.com

# Whop billing (Phase 3)
WHOP_API_KEY=
WHOP_WEBHOOK_SECRET=
# Whop plan IDs -> internal tiers (p19 / p35 / p49)
WHOP_PLAN_19=
WHOP_PLAN_35=
WHOP_PLAN_49=
# Hosted checkout URLs shown on the pricing page
WHOP_CHECKOUT_19=
WHOP_CHECKOUT_35=
WHOP_CHECKOUT_49=

# Job queue (Phase 4)
MAX_CONCURRENT_JOBS=6

# ---- Scalable capability modules (scraper / enrich / whatsapp / audit) ----
# Each capability runs IN-PROCESS by default. To offload one to another VPS, run the
# worker there (`npm run worker -- --modules=scraper`) and point the matching
# *_WORKER_URL below at it. Leave a URL blank to keep that module local.
# SCRAPER_WORKER_URL=http://10.0.0.2:8787
# ENRICH_WORKER_URL=
# WHATSAPP_WORKER_URL=
# AUDIT_WORKER_URL=
# Shared bearer secret the app sends and the worker checks (per-module override:
# e.g. SCRAPER_WORKER_SECRET). Set the SAME value as WORKER_SECRET on that VPS.
WORKER_SECRET=

# ---- Worker process (only on a secondary VPS running `npm run worker`) ----
# Which capabilities this box serves (comma list, or "all"). The worker shares this
# same DATABASE_URL so scraped/enriched rows land in the central DB.
WORKER_MODULES=all
WORKER_PORT=8787

# Feature flags (Phase 6)
# Set to 1 to re-enable the AI agent mode (hidden by default for SaaS launch).
FEATURE_AGENT=0

# Admin panel — standalone username/password login for /admin (set BOTH to enable;
# if either is blank the admin login stays closed). Used to grant/revoke plans.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-strong-password
# Optional: emails that get a convenience "Admin panel" shortcut in the account menu.
ADMIN_EMAILS=ah3573508@gmail.com

# ---- Warehouse (gmaps-scraper-standalone) ------------------------------------
# Direct Postgres connection to the standalone warehouse DB (bypasses the HTTP server).
# Separate from DATABASE_URL — this points at the warehouse Postgres, not the app DB.
# In local dev you need an SSH tunnel to the VPS Postgres, e.g.:
#   ssh -L 5433:127.0.0.1:5433 your-vps "sleep 600"
# then set:
WAREHOUSE_DATABASE_URL=postgresql://warehouse:PASSWORD@127.0.0.1:5433/warehouse
