# ---- LeadsFunda SaaS environment ----
# Copy to .env.local (dev) or .env (prod) and fill in real values.

# Postgres (Phase 1)
DATABASE_URL=postgresql://leadsfunda:password@localhost:5432/leadsfunda
PG_POOL_MAX=10

# Auth.js / Google sign-in (Phase 2)
# Generate AUTH_SECRET with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Public base URL of the app (root domain in prod)
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Whop billing (Phase 3)
WHOP_API_KEY=
WHOP_WEBHOOK_SECRET=
# Whop plan IDs -> internal tiers
WHOP_PLAN_19=
WHOP_PLAN_49=
WHOP_PLAN_99=
# Hosted checkout URLs shown on the pricing page
WHOP_CHECKOUT_19=
WHOP_CHECKOUT_49=
WHOP_CHECKOUT_99=

# Job queue (Phase 4)
MAX_CONCURRENT_JOBS=6

# Feature flags (Phase 6)
# Set to 1 to re-enable the AI agent mode (hidden by default for SaaS launch).
FEATURE_AGENT=0

# Admin panel — standalone username/password login for /admin (set BOTH to enable;
# if either is blank the admin login stays closed). Used to grant/revoke plans.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-strong-password
# Optional: emails that get a convenience "Admin panel" shortcut in the account menu.
ADMIN_EMAILS=ah3573508@gmail.com
